<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/main.css">
    <title>VibeCheck Blog</title>
</head>
<body>
    <div id="toast" class="toast-hidden"></div>
    <div class="container">
        <header>
            <div class="header-top">
                <h1>VibeCheck Blog</h1>
                <button id="theme-toggle" class="theme-btn">🌙 Dark Mode</button>
            </div>
        </header>

        <section class="editor">
            <form action="/submit" method="POST">
                <input type="text" name="title" placeholder="Give this vibe a title..." required>
                
                <div class="image-uploader">
                    <input type="file" id="imageInput" accept="image/*" style="display:none;">
                    <button type="button" class="theme-btn" onclick="document.getElementById('imageInput').click()">
                        📷 Upload Image
                    </button>
                    <small id="uploadStatus"></small>
                </div>

                <textarea id="vibeTextarea" name="content" placeholder="Write your markdown here ..." required></textarea>
                
                <div class="form-footer">
                    <select name="mood">
                        <option value="chill">🍃 Chill</option>
                        <option value="energetic">⚡ Energetic</option>
                        <option value="thoughtful">💎 Thoughtful</option>
                    </select>
                    <button type="submit">Post Vibe</button>
                </div>
            </form>
        </section>

        <hr>

        <div class="search-container">
            <input type="text" id="vibeSearch" placeholder="🔍 Search your vibes...">
        </div>

        <section class="feed" id="vibeFeed">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <% const slug = post.fileName.replace('.md', ''); %>
                    <div class="post-card <%= post.mood %>" data-title="<%= post.displayTitle.toLowerCase() %>">
                        <div class="card-header">
                            <span class="post-date"><%= post.date %></span>
                            <span class="word-badge"><%= post.words %> words</span>
                        </div>
                        
                        <h2><%= post.displayTitle %></h2>
                        
                        <div class="card-actions">
                            <a href="/post/<%= slug %>" class="read-more">Read Vibe →</a>
                            <a href="/edit/<%= slug %>" class="edit-btn">Edit ✏️</a>

                            <form action="/delete" method="POST" style="display:inline;">
                                <input type="hidden" name="fileName" value="<%= post.fileName %>">
                                <button type="submit" class="delete-btn">Delete</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="empty-msg">No vibes recorded yet. Start typing above!</p>
            <% } %>
        </section>
    </div>

    <footer>
        <p>Copyright © <%= new Date().getFullYear() %></p>
    </footer>

    <script>
        // --- 1. DOM Elements ---
        const themeBtn = document.getElementById("theme-toggle");
        const searchInput = document.getElementById('vibeSearch');
        const cards = document.querySelectorAll('.post-card');
        const toast = document.getElementById('toast');
        const imageInput = document.getElementById('imageInput');
        const vibeTextarea = document.getElementById('vibeTextarea');
        const uploadStatus = document.getElementById('uploadStatus');

        // --- 2. Image Upload Logic ---
        if (imageInput && vibeTextarea) {
            imageInput.addEventListener('change', async () => {
                const file = imageInput.files[0];
                if (!file) return;

                const formData = new FormData();
                formData.append('image', file);

                uploadStatus.textContent = "Uploading...";

                try {
                    const response = await fetch('/upload-image', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) throw new Error("Server error during upload");

                    const data = await response.json();
                    
                    // Inserting the markdown image syntax at the current cursor position or end
                    const markdownImage = `\n![Image](${data.url})\n`;
                    vibeTextarea.value += markdownImage;
                    uploadStatus.textContent = "✅ Image linked!";
                    
                    // Clearing the input so that user can upload the same file again if needed
                    imageInput.value = '';
                } catch (err) {
                    console.error("Upload Error:", err);
                    uploadStatus.textContent = "❌ Upload failed.";
                }
            });
        }

        // --- 3. Dark Mode Logic ---
        if (localStorage.getItem("theme") === "dark") {
            document.documentElement.setAttribute("data-theme", "dark");
            themeBtn.textContent = "☀️ Light Mode";
        }

        themeBtn.addEventListener("click", () => {
            if (document.documentElement.getAttribute("data-theme") === "dark") {
                document.documentElement.removeAttribute("data-theme");
                themeBtn.textContent = "🌙 Dark Mode";
                localStorage.setItem("theme", "light");
            } else {
                document.documentElement.setAttribute("data-theme", "dark");
                themeBtn.textContent = "☀️ Light Mode";
                localStorage.setItem("theme", "dark");
            }
        });

        // --- 4. Live Search Logic ---
        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            cards.forEach(card => {
                const title = card.getAttribute('data-title');
                card.style.display = title.includes(term) ? "block" : "none";
            });
        });

        // --- 5. Toast Notification Logic ---
        const urlParams = new URLSearchParams(window.location.search);
        const msgType = urlParams.get('msg');

        if (msgType) {
            const messages = {
                created: "✨ Vibe posted successfully!",
                updated: "📝 Vibe updated!",
                deleted: "🗑️ Vibe deleted."
            };

            if (messages[msgType]) {
                toast.textContent = messages[msgType];
                toast.className = "toast-visible";
                setTimeout(() => {
                    toast.className = "toast-hidden";
                    window.history.replaceState({}, document.title, "/");
                }, 3000);
            }
        }

        // --- 6. Confirm Delete Logic ---
        const deleteForms = document.querySelectorAll('form[action="/delete"]');
        deleteForms.forEach(form => {
            form.addEventListener('submit', (e) => {
                if (!confirm("Are you sure you want to delete this vibe?")) {
                    e.preventDefault();
                }
            });
        });
    </script>
</body>
</html>